#!/bin/sh
# 提交门禁:gofmt + go build + go vet + golangci-lint(仅当有 .go 改动)。
# 启用:git config core.hooksPath .githooks(本仓已设)。零额外依赖(用本机 Go 工具链)。
set -e
export PATH="$HOME/.local/go/bin:$HOME/go/bin:$PATH"

gofiles=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
[ -z "$gofiles" ] && exit 0

unformatted=$(gofmt -l $gofiles)
if [ -n "$unformatted" ]; then
  echo "✗ gofmt 未格式化:"; echo "$unformatted"; echo "  修复: gofmt -w <file>"; exit 1
fi

echo ">> go build ./..." && go build ./...
echo ">> go vet ./..."   && go vet ./...
echo ">> golangci-lint"  && golangci-lint run ./...
echo "✓ pre-commit OK"
