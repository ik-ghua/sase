# Copy this file to .mcp-atlassian.env and fill in the values you need.
# Keep .mcp-atlassian.env out of git because it contains tokens.

# Jira Cloud example:
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_USERNAME=you@example.com
# JIRA_API_TOKEN=your-api-token

# Confluence Cloud example:
# CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
# CONFLUENCE_USERNAME=you@example.com
# CONFLUENCE_API_TOKEN=your-api-token

# Optional filters:
# JIRA_PROJECTS_FILTER=PROJ,OPS
# CONFLUENCE_SPACES_FILTER=ENG,DOCS

# Optional:
# READ_ONLY_MODE=true
# TOOLSETS=all
