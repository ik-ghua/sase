# deploy/.env.example —— 复制为 deploy/.env 后 `docker compose` 自动读取(同目录)。
# 所有值都有 compose 内默认,本文件仅在你要覆盖时用。⚠️ 全部 dev 用途,生产严禁原样使用。

# ---- Postgres(superuser,仅迁移容器用;应用走 app_* 角色) ----
PG_SUPERUSER=postgres
PG_SUPERPASS=postgres
PG_DB=sase

# ---- 应用角色密码(必须与 migrations 内 CREATE ROLE 的密码一致;改这里也要改迁移,故一般别动) ----
APP_RW_PASS=app_rw_dev
APP_RO_PASS=app_ro_dev
APP_PLATFORM_RO_PASS=app_platform_ro_dev
APP_PLATFORM_RW_PASS=app_platform_rw_dev

# ---- 引导 platform_admin ----
# api-server 启动时为该 subject 签发一枚 15min platform_admin 令牌并打印到日志
# (`docker compose logs api-server | grep 引导`)。取用后建议清空本项再重启(否则每次重启再签一枚)。
BOOTSTRAP_PLATFORM_ADMIN=ops@demo.local

# ---- 凭证/密钥(固定值 → 重启稳定;dev 专用) ----
# ed25519 种子:base64url(RawURLEncoding,无填充),解码须恰 32 字节。
CRED_ED25519_SEED=c2FzZS1kZW1vLWVkMjU1MTktc2VlZC0zMmJ5dGVBQiE
# secret 模块 dev KEK:base64(StdEncoding,带填充),解码须恰 32 字节。
DEV_KEK=c2FzZS1kZW1vLWRldi1rZWstMzJieXRlcy1BQkNERSE=

# ---- demo 租户(pop-agent 订阅的租户;须与 scripts/seed.sql 固定 UUID 一致) ----
DEMO_TENANT_ID=11111111-1111-1111-1111-111111111111
POP_NODE=pop-demo

# ---- CSRF 允许的浏览器源(前端访问;逗号分隔) ----
CSRF_ALLOWED_ORIGINS=http://localhost:5173,https://localhost:8443

# ---- 安全硬化开关(dev 默认关;生产置 1) ----
# xds-server:role-less/无证书订阅被拒(role:device 跨租户始终拒,与本开关无关)。
XDS_REQUIRE_CERT_SCOPE=0
# pop-agent:反向通道注册仅接受 ZTP 租户绑定证书(W9 fail-closed)。
REQUIRE_CERT_TENANT=0

# ---- 宿主暴露端口(按需改,避免与本机其它服务冲突) ----
ADMIN_PORT=8443
DEVICE_PORT=8444
AGENTCTL_PORT=8082
INGRESS_PORT=8081

# ---- 前端(可选;本地 pnpm dev 指向 compose 的 api-server) ----
# 在 web/admin 下:VITE_API_TARGET=https://localhost:8443 pnpm dev
